generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ORG_MEMBER
}

enum OrgRole {
  ADMIN
  MEMBER
  VIEWER
}

enum ServiceType {
  WEB_DEV
  AI
  AUTOMATION
  SOFTWARE
}

enum ServiceStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum NotificationType {
  ACTION_REQUIRED
  INFO
  SUCCESS
  WARNING
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  TECHNICAL
  BILLING
  FEATURE_REQUEST
  OTHER
}

enum AssetType {
  DOCUMENT
  IMAGE
  BRANDBOOK
  LOGO
  ACCESS
  OTHER
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  role               Role      @default(ORG_MEMBER)
  unlockedFeatures   String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastDashboardVisit DateTime?

  accounts        Account[]
  sessions        Session[]
  orgMemberships  OrgMember[]
  resetTokens     PasswordResetToken[]
  notifications   Notification[]
  tickets         Ticket[]
  ticketMessages  TicketMessage[]
  businessMetrics BusinessMetric[]
  assignedTasks   Task[]               @relation("TaskAssignee")
  osAssignedLeads OsLead[]             @relation("OsLeadAssignee")
  osActivities    OsLeadActivity[]     @relation("OsActivityPerformer")
  osTimeEntries   OsTimeEntry[]        @relation("OsTimeEntryUser")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Modelos de Negocio ───────────────────────────────────────────────────────

model Organization {
  id                  String   @id @default(cuid())
  companyName         String
  slug                String   @unique
  logoUrl             String?
  analyticsPropertyId String?
  siteUrl             String?
  n8nWorkflowIds      String[]
  onboardingCompleted Boolean  @default(false)
  whatsapp            String?
  notificationPrefs   Json?
  createdAt           DateTime @default(now())

  // Health Score: connection status
  // Structure: { ga4: {connected, lastSync}, searchConsole: {...}, ... }
  dataConnections Json? @default("{\"ga4\":{\"connected\":false,\"lastSync\":null},\"searchConsole\":{\"connected\":false,\"lastSync\":null},\"googleBusinessProfile\":{\"connected\":false,\"lastSync\":null},\"whatsappBusiness\":{\"connected\":false,\"lastSync\":null},\"afip\":{\"connected\":false,\"lastSync\":null},\"pixel\":{\"connected\":false,\"lastSync\":null}}")

  // Google reputation. Manual first, API when Reviews Engine is sold.
  googleRating          Float?
  googleReviewsCount    Int?      @default(0)
  googleRatingUpdatedAt DateTime?

  // Weekly AIBrief cache
  cachedExecutiveBrief        String?   @db.Text
  cachedExecutiveBriefAt      DateTime?
  executiveBriefRegenerations Int       @default(0)

  members        OrgMember[]
  services       Service[]
  projects       Project[]
  messages       Message[]
  invoices       Invoice[]
  notifications  Notification[]
  clientAssets   ClientAsset[]
  subscription   Subscription?
  brandProfile   ClientBrandProfile?
  tickets        Ticket[]
  premiumModules OrganizationModule[]
}

model OrgMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(ADMIN)
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Service {
  id        String        @id @default(cuid())
  type      ServiceType
  status    ServiceStatus @default(ACTIVE)
  startDate DateTime      @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Project {
  id                   String        @id @default(cuid())
  name                 String
  description          String?
  status               ProjectStatus @default(PLANNING)
  agreedAmount         Decimal?      @db.Decimal(10, 2)
  monthlyRate          Decimal?      @db.Decimal(10, 2)
  maintenanceStartDate DateTime?
  deliveredAt          DateTime?
  estimatedEndDate     DateTime?
  osLeadId             String?       @unique

  organizationId      String?
  organization        Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  tasks               Task[]
  osLead              OsLead?                @relation(fields: [osLeadId], references: [id])
  paymentMilestones   OsPaymentMilestone[]
  maintenancePayments OsMaintenancePayment[]
  timeEntries         OsTimeEntry[]
}

model Task {
  id              String          @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus      @default(TODO)
  dueDate         DateTime?
  approvalStatus  ApprovalStatus?
  rejectionReason String?         @db.Text
  estimatedHours  Float?
  position        Int?            @default(0)
  assignedToId    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo    User?          @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notifications Notification[]
  osTimeEntries OsTimeEntry[]

  @@index([assignedToId])
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  fromAdmin Boolean  @default(false)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String             @unique
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planName       String
  status         SubscriptionStatus @default(ACTIVE)
  price          Float
  currency       String             @default("USD")
  renewalDate    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Invoice {
  id          String        @id @default(cuid())
  amount      Float
  currency    String        @default("USD")
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  paymentLink String?
  pdfUrl      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ContactSubmission {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  company    String?
  service    String?
  message    String   @db.Text
  read       Boolean  @default(false)
  leadStatus String?  @default("NUEVO")
  leadNotes  String?  @db.Text
  createdAt  DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(INFO)
  title     String
  message   String
  read      Boolean          @default(false)
  actionUrl String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ClientAsset {
  id          String    @id @default(cuid())
  name        String
  url         String
  type        AssetType @default(OTHER)
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ClientBrandProfile {
  id             String   @id @default(cuid())
  primaryColor   String?
  secondaryColor String?
  toneOfVoice    String?  @db.Text
  targetAudience String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Ticket {
  id             String          @id @default(cuid())
  title          String
  category       TicketCategory  @default(TECHNICAL)
  status         TicketStatus    @default(OPEN)
  priority       TicketPriority  @default(MEDIUM)
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       TicketMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([userId])
}

model BusinessMetric {
  id              String   @id @default(cuid())
  clientId        String
  client          User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month           String
  monthlyVisitors Int
  bounceRate      Float
  avgTicketPrice  Float
  createdAt       DateTime @default(now())

  @@index([clientId])
}

model PageView {
  id        String   @id @default(cuid())
  clientId  String
  url       String
  duration  Int?
  createdAt DateTime @default(now())

  @@index([clientId])
}

model AgencySettings {
  id                           String   @id @default(cuid())
  agencyName                   String   @default("develOP")
  contactEmail                 String?
  contactWhatsapp              String?
  websiteUrl                   String?
  alertWebhookUrl              String?
  alertOnTickets               Boolean  @default(true)
  alertOnLeads                 Boolean  @default(true)
  alertOnChurn                 Boolean  @default(true)
  alertOnExpiringSubscriptions Boolean  @default(true)
  alertOnClientMessages        Boolean  @default(false)
  osWeeklyDemoTarget           Int      @default(8)
  osTelegramBotToken           String?
  osTelegramChatId             String?
  updatedAt                    DateTime @updatedAt
}

model OsLead {
  id             String         @id @default(cuid())
  businessName   String
  contactName    String?
  phone          String?
  email          String?
  industry       String?
  zone           String?
  source         String?
  instagramUrl   String?
  currentWebUrl  String?
  googleMapsUrl  String?
  status         LeadStatus     @default(PROSPECTO)
  serviceType    OsServiceType?
  nextFollowUpAt DateTime?
  reactivateAt   DateTime?
  notes          String?
  assignedToId   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  assignedTo User?            @relation("OsLeadAssignee", fields: [assignedToId], references: [id])
  activities OsLeadActivity[]
  demos      OsDemo[]
  project    Project?

  @@index([status])
  @@index([nextFollowUpAt])
  @@index([status, nextFollowUpAt])
  @@index([assignedToId])
}

model OsLeadActivity {
  id            String          @id @default(cuid())
  leadId        String
  channel       ActivityChannel
  result        ActivityResult?
  notes         String?
  performedById String?
  createdAt     DateTime        @default(now())

  lead        OsLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  performedBy User?  @relation("OsActivityPerformer", fields: [performedById], references: [id])

  @@index([leadId, createdAt])
}

model OsDemo {
  id          String         @id @default(cuid())
  leadId      String
  serviceType OsServiceType?
  demoUrl     String
  loomUrl     String?
  sentAt      DateTime       @default(now())
  viewedAt    DateTime?
  notes       String?
  createdAt   DateTime       @default(now())

  lead OsLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model OsPaymentMilestone {
  id        String        @id @default(cuid())
  projectId String
  type      MilestoneType
  amount    Decimal       @db.Decimal(10, 2)
  dueAt     DateTime?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model OsMaintenancePayment {
  id        String    @id @default(cuid())
  projectId String
  month     Int
  year      Int
  amount    Decimal   @db.Decimal(10, 2)
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, month, year])
  @@index([projectId])
}

model OsTimeEntry {
  id        String    @id @default(cuid())
  taskId    String
  projectId String?
  userId    String
  hours     Float
  startedAt DateTime?
  endedAt   DateTime?
  date      DateTime
  notes     String?
  createdAt DateTime  @default(now())

  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation("OsTimeEntryUser", fields: [userId], references: [id])

  @@index([taskId])
  @@index([projectId])
  @@index([userId, date])
}

enum LeadStatus {
  PROSPECTO
  DEMO_ENVIADA
  VIO_VIDEO
  RESPONDIO
  CALL_AGENDADA
  CERRADO
  PERDIDO
  POSTERGADO
}

enum OsServiceType {
  WEB
  AI_AGENT
  AUTOMATION
  CUSTOM_SOFTWARE
}

enum ActivityChannel {
  INSTAGRAM_DM
  WHATSAPP
  EMAIL
  LLAMADA
  LOOM_VIDEO
  OTRO
}

enum ActivityResult {
  SIN_RESPUESTA
  RESPONDIO
  CALL_AGENDADA
  RECHAZADO
  POSTERGADO
}

enum MilestoneType {
  INICIO
  ENTREGA
}

enum PremiumModuleTier {
  TIER_1_OPERATION
  TIER_2_GROWTH
  TIER_3_VERTICAL
}

enum PremiumModuleStatus {
  ACTIVE
  COMING_SOON
  DEPRECATED
}

enum OrganizationModuleStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model PremiumModule {
  id               String              @id @default(cuid())
  slug             String              @unique
  name             String
  shortDescription String
  longDescription  String?
  tier             PremiumModuleTier
  priceMonthlyUsd  Float
  iconName         String // nombre de icono Lucide (ej: "MessageCircle")
  accentColor      String // hex color (ej: "#06b6d4")
  validRubros      String[] // [] = todos los rubros
  status           PremiumModuleStatus @default(ACTIVE)
  sortOrder        Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organizations OrganizationModule[]

  @@index([tier])
  @@index([status])
  @@map("premium_module")
}

model OrganizationModule {
  id             String                   @id @default(cuid())
  organizationId String
  moduleId       String
  status         OrganizationModuleStatus @default(ACTIVE)
  activatedAt    DateTime                 @default(now())
  cancelledAt    DateTime?
  pausedAt       DateTime?
  priceLockedUsd Float

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       PremiumModule @relation(fields: [moduleId], references: [id], onDelete: Restrict)

  @@unique([organizationId, moduleId])
  @@index([organizationId])
  @@index([status])
  @@map("organization_module")
}
